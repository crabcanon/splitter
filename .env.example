# Application
SPLITTER_APP_NAME=splitter
SPLITTER_APP_VERSION=0.1.0
SPLITTER_HOST=0.0.0.0
SPLITTER_PORT=8000
SPLITTER_RELOAD=false

# Default LLM provider loaded by the application.
# Keep real keys in your local .env or secret manager, not in source control.
SPLITTER_LLM_PROVIDER=openai
SPLITTER_LLM_MODEL=gpt-4.1-mini
SPLITTER_LLM_BASE_URL=https://api.openai.com/v1
SPLITTER_LLM_API_KEY=

# Default embedding provider loaded by the application.
# Leave blank for local validation; SemanticSplitterNodeParser will use MockEmbedding.
SPLITTER_EMBEDDING_PROVIDER=
SPLITTER_EMBEDDING_MODEL=
SPLITTER_EMBEDDING_BASE_URL=
SPLITTER_EMBEDDING_API_KEY=
